# --- FRONTEND (Vite) ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_API_BASE_URL="https://xlayer.agentmolt.live" # Change to your Render URL
VITE_WALLETCONNECT_PROJECT_ID="your-walletconnect-project-id"

# --- BACKEND (Node) ---
PORT=3001
KEEPER_WALLET="0x..."
HUNTER_WALLET="0x..."
ARCHITECT_WALLET="0x..."

# --- ONCHAIN OS (OKX) ---
# OKX Web3 Developer Portal credentials used by the Supabase edge proxy for live DEX swap quotes.
# These are OPTIONAL — the app uses mock vault data and mock swap routes when not set.
# Note: OKX Web3 DEX services are not available in all regions (e.g. Nigeria). If you cannot
# obtain these, the app still works fully in demo/mock mode without them.
OKX_PROJECT_ID="your-okx-web3-project-id"
OKX_API_KEY="your-okx-api-key"
OKX_SECRET_KEY="your-okx-secret"
OKX_PASSPHRASE="your-okx-passphrase"
